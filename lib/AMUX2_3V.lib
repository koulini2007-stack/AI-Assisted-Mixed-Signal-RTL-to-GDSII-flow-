library(AMUX2_3V_lib) {

    input_threshold_pct_rise : 50;
    input_threshold_pct_fall : 50;

    output_threshold_pct_rise : 50;
    output_threshold_pct_fall : 50;

    slew_lower_threshold_pct_rise : 20;
    slew_upper_threshold_pct_rise : 80;

    slew_lower_threshold_pct_fall : 20;
    slew_upper_threshold_pct_fall : 80;
    technology("cmos");
    delay_model : table_lookup;
    time_unit : "1ns";
    voltage_unit : "1V";
    current_unit : "1mA";
    pulling_resistance_unit : "1kohm";
    leakage_power_unit : "1nW";
    capacitive_load_unit(1,pf);
    nom_voltage : 1.8;
    nom_temperature : 25;
    operating_conditions(TT) {
        process : 1;
        voltage : 1.8;
        temperature : 25;
    }
    default_operating_conditions : TT;
    cell(AMUX2_3V) {
        area : 100;
        pin(I0) {

            direction : input;
            capacitance : 0.01;

        }
        pin(I1) {

            direction : input;
            capacitance : 0.01;

        }
        pin(select) {

            direction : input;
            capacitance : 0.01;

        }
        pin(out) {

            direction : output;
            function : "(select & I1) | (!select & I0)";
            timing() {

                related_pin : "I0";
                timing_type : combinational;

                cell_rise(delay_template) {
                    values("0.10");
                }

                cell_fall(delay_template) {
                    values("0.10");
                }

                rise_transition(delay_template) {
                    values("0.05");
                }

                fall_transition(delay_template) {
                    values("0.05");
                }

            }
            timing() {

                related_pin : "I1";
                timing_type : combinational;

                cell_rise(delay_template) {
                    values("0.10");
                }

                cell_fall(delay_template) {
                    values("0.10");
                }

                rise_transition(delay_template) {
                    values("0.05");
                }

                fall_transition(delay_template) {
                    values("0.05");
                }
            }
            timing() {

                related_pin : "select";
                timing_type : combinational;

                cell_rise(delay_template) {
                    values("0.15");
                }

                cell_fall(delay_template) {
                    values("0.15");
                }

                rise_transition(delay_template) {
                    values("0.05");
                }

                fall_transition(delay_template) {
                    values("0.05");
                }
            }
        }
    }

}
